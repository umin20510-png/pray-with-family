var pendingAns=null;
function renderPray(){
  var rows=allPray;
  if(!isLeader){
    rows=rows.filter(function(r){
      var p=(r.c4||'').trim();
      return p==='public'||p==='모임에서 공개'||p==='';
    });
  }
  rows=prayMode==='active'?rows.filter(function(r){return r.c5!=='Y';}):rows.filter(function(r){return r.c5==='Y';});
  visiblePray=rows.slice().reverse();
  $('prayCount').textContent=visiblePray.length+'개의 기도제목';
  if(!visiblePray.length){
    $('prayList').innerHTML='<div class="empty"><span class="empty-icon">'+(prayMode==='active'?'🙏':'🙌')+'</span>'+(prayMode==='active'?'기도제목이 없어요<br>첫 번째로 올려보세요!':'응답된 기도제목이 없어요')+'</div>';
    return;
  }
  $('prayList').innerHTML=visiblePray.map(function(p,i){
    var answered=p.c5==='Y';
    var isPriv=(p.c4||'').trim()==='private'||(p.c4||'').trim()==='리더만 보기';
    var isSel=checkedPray.indexOf(p.rowIndex)!==-1;
    var ac=avatarColor(p.c1);
    var catB=p.c3?'<span class="badge badge-cat">'+p.c3.split(',')[0].trim()+'</span>':'';
    var privB=isPriv?'<span class="badge badge-priv">🔒 비공개</span>':'';
    return '<div class="pi'+(answered?' answered':'')+(isSel?' sel':'')+'" data-idx="'+p.rowIndex+'" style="animation-delay:'+(i*.05)+'s">'+
      '<div class="pi-row">'+
        '<input type="checkbox" class="pi-cb'+(isLeader?' show':'')+'"'+(isSel?' checked':'')+' onchange="toggleCheckPray('+p.rowIndex+')"/>'+
        '<div class="pi-body">'+
          '<div class="pi-top">'+
            '<div class="pi-left">'+
              '<div class="av" style="background:'+ac+'22;color:'+ac+'">'+p.c1.slice(0,1)+'</div>'+
              '<span class="pi-name">'+p.c1+'</span>'+catB+privB+
              (answered?'<span class="ans-tag">응답됨 🙌</span>':'')+
            '</div>'+
            '<div style="display:flex;align-items:center;gap:6px">'+
              '<span class="pi-date">'+fmtDate(p.c0)+'</span>'+
              (!answered?'<button class="ans-btn" onclick="askAnswered('+p.rowIndex+',\''+p.c2.slice(0,20).replace(/'/g,"\\'")+'\')">응답됐어요</button>':'')+
            '</div>'+
          '</div>'+
          '<p class="pi-text">'+String(p.c2||'').replace(/</g,'&lt;')+'</p>'+
        '</div>'+
      '</div>'+
    '</div>';
  }).join('');
}
function toggleCheckPray(rowIndex){
  var idx=checkedPray.indexOf(rowIndex);
  if(idx===-1)checkedPray.push(rowIndex);else checkedPray.splice(idx,1);
  updateDelUIPray();
}
function updateDelUIPray(){
  var n=checkedPray.length;
  $('selCountPray').textContent=n+'개 선택';
  $('btnDelPray').disabled=n===0;
  var allSel=n===visiblePray.length&&visiblePray.length>0;
  var btn=$('btnSelAllPray');
  btn.classList.toggle('on',allSel);
  btn.textContent=allSel?'전체 해제':'전체 선택';
  document.querySelectorAll('.pi').forEach(function(el){
    var idx=parseInt(el.dataset.idx);
    el.classList.toggle('sel',checkedPray.indexOf(idx)!==-1);
    var cb=el.querySelector('.pi-cb');
    if(cb)cb.checked=checkedPray.indexOf(idx)!==-1;
  });
