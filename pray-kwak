function fmtDate(str){
  if(!str)return'';
  var s=String(str);
  if(s.indexOf('Date(')!==-1){
    var m=s.match(/Date\((\d+),(\d+),(\d+)/);
    if(m)return m[1]+'.'+(parseInt(m[2])+1)+'.'+m[3];
  }
  return s.slice(0,10).replace(/-/g,'.');
}
function avatarColor(name){
  var colors=['#8B7355','#4A7C59','#4A6FA5','#C49A3C','#854F0B','#B91C1C','#0F6E56','#4A3F8F'];
  var idx={'곽유민':0,'김서현':1,'박서현':2,'이은휼':3,'김한을':4,'최유진':5,'조안나':6,'이규환':7}[name]||0;
  return colors[idx];
}
function postData(payload,onDone){
  fetch(SHEET_URL,{method:'POST',mode:'no-cors',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)}).catch(function(){}).finally(onDone);
}
function gvizFetch(sheetName,callback){
  var old=document.getElementById('__gviz_'+sheetName);
  if(old)old.remove();
  var timer=setTimeout(function(){callback(null);},10000);
  window.google=window.google||{};
  window.google.visualization=window.google.visualization||{};
  window.google.visualization.Query=window.google.visualization.Query||{};
  window.google.visualization.Query.setResponse=function(res){
    clearTimeout(timer);
    try{
      var rows=(res.table&&res.table.rows)?res.table.rows:[];
      var data=rows.map(function(r,i){
        var c=r.c||[];
        var obj={rowIndex:i+2};
        c.forEach(function(cell,j){obj['c'+j]=cell&&cell.v!=null?String(cell.v):'';});
        return obj;
      }).filter(function(r){return r.c1||r.c2;});
      callback(data);
    }catch(e){callback(null);}
  };
  var s=document.createElement('script');
  s.id='__gviz_'+sheetName;
  s.src=GVIZ+'&sheet='+encodeURIComponent(sheetName)+'&t='+Date.now();
  document.head.appendChild(s);
}

