    allThank=data;renderThank();
  });
}

function renderThank(){
  visibleThank=allThank.slice().reverse();
  $('thankCount').textContent=visibleThank.length+'개의 감사 제목';
  if(!visibleThank.length){
    $('thankList').innerHTML='<div class="empty"><span class="empty-icon">🌱</span>감사 제목이 없어요<br>오늘 감사한 것을 써봐요!</div>';
    return;
  }
  var groups={},order=[];
  visibleThank.forEach(function(r){
    var d=fmtDate(r.c0)||'날짜 없음';
    if(!groups[d]){groups[d]=[];order.push(d);}
    groups[d].push(r);
  });
  $('thankList').innerHTML=order.map(function(date){
    var entries=groups[date];
    return '<div class="gi-date-group">'+date+'</div>'+
      entries.map(function(r){
        var isSel=checkedThank.indexOf(r.rowIndex)!==-1;
        var ac=avatarColor(r.c1);
        return '<div class="gi'+(isSel?' sel':'')+'" data-idx="'+r.rowIndex+'" style="padding:8px 16px">'+
          '<div style="display:flex;gap:10px;align-items:flex-start">'+
            '<input type="checkbox" class="pi-cb'+(isLeader?' show':'')+'"'+(isSel?' checked':'')+' onchange="toggleCheckThank('+r.rowIndex+')"/>'+
            '<div class="gi-entry" style="border:none;flex:1">'+
              '<div class="gi-dot" style="background:'+ac+'"></div>'+
              '<div class="gi-body">'+
                '<div class="gi-who">'+r.c1+'</div>'+
                '<div class="gi-content">'+String(r.c2||'').replace(/</g,'&lt;')+'</div>'+
              '</div>'+
            '</div>'+
          '</div>'+
        '</div>';
      }).join('');
  }).join('');
}
