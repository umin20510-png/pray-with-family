});

$('btnDelCancel').addEventListener('click',function(){$('mDelete').classList.remove('open');});
$('btnDelOk').addEventListener('click',function(){
  $('mDelete').classList.remove('open');
  var indexes=curDelType==='기도제목'?checkedPray:curDelType==='감사일기'?checkedThank:checkedMedi;
  if(!indexes.length)return;
  var s=document.createElement('script');
  s.src=SHEET_URL+'?action=delete&sheet='+encodeURIComponent(curDelType)+'&rows='+indexes.join(',')+'&callback=__delCb&t='+Date.now();
  document.head.appendChild(s);
  window.__delCb=function(){
    if(curDelType==='기도제목'){
      allPray=allPray.filter(function(r){return indexes.indexOf(r.rowIndex)===-1;});
      checkedPray=[];renderPray();updateDelUIPray();
    }else if(curDelType==='감사일기'){
      allThank=allThank.filter(function(r){return indexes.indexOf(r.rowIndex)===-1;});
      checkedThank=[];renderThank();updateDelUIThank();
    }else{
      allMedi=allMedi.filter(function(r){return indexes.indexOf(r.rowIndex)===-1;});
      checkedMedi=[];renderMedi();updateDelUIMedi();
    }
  };
});

fetchPray();
</script>
</body>
</html>
