<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0"/>
<title>곽유민조 기도방 🙏</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@400;600;700&family=Noto+Sans+KR:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --cream:#FAF7F2;--warm:#F2EDE4;--stone:#E8E0D4;--bark:#8B7355;--soil:#5C4A32;
  --leaf:#4A7C59;--leaf-light:#E8F2EB;--sky:#4A6FA5;--sky-light:#E8EEF6;
  --gold:#C49A3C;--gold-light:#FDF5E0;--amber:#854F0B;--amber-light:#FAEEDA;
  --text:#2C2419;--muted:#9A8B78;--border:#DDD5C8;--red:#B91C1C;--red-light:#FEE2E2;
  --r:16px;--rs:10px;
}
html,body{background:var(--cream);font-family:'Noto Sans KR',sans-serif;color:var(--text);min-height:100vh;-webkit-text-size-adjust:100%}
body::before{content:'';position:fixed;inset:0;background:radial-gradient(ellipse at 20% 20%,rgba(196,154,60,.06) 0%,transparent 50%),radial-gradient(ellipse at 80% 80%,rgba(74,124,89,.06) 0%,transparent 50%);pointer-events:none;z-index:0}

.wrap{max-width:480px;margin:0 auto;padding:0 16px 100px;position:relative;z-index:1}
.hd{text-align:center;padding:44px 0 32px}
.hd-tag{display:inline-flex;align-items:center;gap:6px;background:var(--gold-light);color:var(--gold);font-size:11px;font-weight:500;padding:4px 12px;border-radius:20px;margin-bottom:16px;border:1px solid rgba(196,154,60,.2);letter-spacing:.05em}
.hd h1{font-family:'Noto Serif KR',serif;font-size:26px;font-weight:700;color:var(--soil);line-height:1.3;margin-bottom:6px}
.hd p{font-size:13px;color:var(--muted)}

.fam-wrap{background:var(--warm);border:1px solid var(--border);border-radius:var(--r);padding:16px;margin-bottom:20px}
.fam-label{font-size:11px;font-weight:500;color:var(--muted);letter-spacing:.06em;text-transform:uppercase;margin-bottom:10px;display:block}
.fam-chips{display:flex;gap:8px;flex-wrap:wrap}
.fam-chip{font-size:14px;padding:8px 18px;border-radius:20px;border:1.5px solid var(--border);background:#fff;color:var(--muted);cursor:pointer;transition:all .2s;user-select:none;font-weight:400}
.fam-chip.on{background:var(--soil);color:#fff;border-color:var(--soil);font-weight:500}

.tabs{display:flex;gap:0;margin-bottom:24px;background:var(--warm);border:1px solid var(--border);border-radius:var(--r);padding:5px;overflow:hidden}
.tab{flex:1;text-align:center;padding:10px 4px;font-size:13px;border-radius:12px;cursor:pointer;color:var(--muted);transition:all .2s;user-select:none;line-height:1.3}
.tab .tab-icon{font-size:16px;display:block;margin-bottom:2px}
.tab.on{background:#fff;color:var(--soil);font-weight:500;box-shadow:0 2px 8px rgba(92,74,50,.1)}

.card{background:#fff;border:1px solid var(--border);border-radius:var(--r);padding:18px 20px;margin-bottom:12px;transition:box-shadow .2s}
.card:hover{box-shadow:0 4px 16px rgba(92,74,50,.06)}
.lbl{font-size:11px;font-weight:500;color:var(--muted);text-transform:uppercase;letter-spacing:.07em;margin-bottom:10px;display:block}
.req{color:var(--gold);margin-left:2px}

input[type=text],input[type=password],textarea{width:100%;font-family:'Noto Sans KR',sans-serif;font-size:15px;color:var(--text);background:var(--cream);border:1.5px solid var(--border);border-radius:var(--rs);padding:11px 14px;-webkit-appearance:none;appearance:none;transition:border-color .2s;line-height:1.5}
input:focus,textarea:focus{outline:none;border-color:var(--bark)}
input::placeholder,textarea::placeholder{color:#C4B9AC}
textarea{resize:none;line-height:1.65}
textarea.sm{height:80px}
textarea.md{height:110px}
textarea.lg{height:130px}

.cats{display:flex;flex-wrap:wrap;gap:8px}
.cat{font-size:13px;padding:6px 14px;border-radius:20px;border:1px solid var(--border);background:var(--bg);color:var(--muted);cursor:pointer;transition:all .15s;user-select:none}
.cat.on{background:var(--sky-light);color:var(--sky);border-color:#AFA9EC}

.prv{display:flex;gap:8px}
.prv-btn{flex:1;padding:10px;font-size:13px;font-family:'Noto Sans KR',sans-serif;border-radius:var(--rs);border:1px solid var(--border);background:var(--bg);color:var(--muted);cursor:pointer;text-align:center;transition:all .15s}
.prv-btn.on{background:var(--leaf-light);color:var(--leaf);border-color:#5DCAA5;font-weight:500}

.btn-main{width:100%;padding:14px;font-size:15px;font-weight:500;font-family:'Noto Sans KR',sans-serif;background:var(--soil);color:#fff;border:none;border-radius:var(--r);cursor:pointer;margin-top:4px;transition:opacity .15s,transform .1s}
.btn-main:hover{opacity:.88}.btn-main:active{transform:scale(.98)}.btn-main:disabled{opacity:.4;cursor:not-allowed}
.btn-leaf{background:var(--leaf)}.btn-sky{background:var(--sky)}

.ok{display:none;text-align:center;padding:44px 0 28px}
.ok-icon{font-size:48px;margin-bottom:14px;display:block}
.ok h2{font-family:'Noto Serif KR',serif;font-size:22px;color:var(--soil);margin-bottom:8px}
.ok p{font-size:14px;color:var(--muted);margin-bottom:24px}
.out-btn{display:inline-block;padding:9px 22px;font-size:13px;font-family:'Noto Sans KR',sans-serif;background:transparent;color:var(--soil);border:1.5px solid var(--soil);border-radius:24px;cursor:pointer;transition:all .15s}
.out-btn:hover{background:var(--warm)}

.lt{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;gap:8px}
.lc{font-size:13px;color:var(--muted)}
.ic-btn{font-size:12px;padding:6px 14px;border-radius:20px;border:1px solid var(--border);background:#fff;color:var(--muted);cursor:pointer;font-family:'Noto Sans KR',sans-serif;transition:all .15s}
.ic-btn:hover{border-color:var(--bark);color:var(--bark)}
.ic-btn.on{background:var(--amber-light);color:var(--amber);border-color:#EF9F27;font-weight:500}

.del-bar{display:none;background:var(--red-light);border:1px solid #FECACA;border-radius:var(--rs);padding:10px 14px;margin-bottom:12px;align-items:center;justify-content:space-between;gap:8px}
.del-bar.show{display:flex}
.sa-btn{font-size:13px;font-family:'Noto Sans KR',sans-serif;color:var(--red);background:transparent;border:1px solid #FECACA;border-radius:20px;padding:5px 12px;cursor:pointer;white-space:nowrap}
.sa-btn.on{background:var(--red);color:#fff;border-color:var(--red)}
.sc{font-size:13px;color:var(--red);flex:1;text-align:center}
.d-btn{font-size:13px;font-family:'Noto Sans KR',sans-serif;background:var(--red);color:#fff;border:none;border-radius:20px;padding:6px 16px;cursor:pointer;white-space:nowrap}
.d-btn:disabled{opacity:.4;cursor:not-allowed}

.pi{background:#fff;border:1px solid var(--border);border-radius:var(--r);padding:16px 18px;margin-bottom:10px;animation:fu .25s ease both;transition:all .2s}
.pi.answered{background:var(--leaf-light);border-color:rgba(74,124,89,.25)}
.pi.sel{border-color:var(--red);background:#FFF8F8}
.pi-row{display:flex;gap:10px;align-items:flex-start}
.pi-cb{width:18px;height:18px;margin-top:3px;accent-color:var(--red);flex-shrink:0;cursor:pointer;display:none}
.pi-cb.show{display:block}
.pi-body{flex:1;min-width:0}
.pi-top{display:flex;align-items:flex-start;justify-content:space-between;gap:8px;margin-bottom:8px}
.pi-left{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.av{width:28px;height:28px;border-radius:50%;background:var(--warm);color:var(--soil);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0;border:1px solid var(--border)}
.pi-name{font-size:13px;font-weight:500;color:var(--soil)}
.pi-date{font-size:11px;color:var(--muted);white-space:nowrap}
.pi-text{font-size:14px;line-height:1.7;color:var(--text);word-break:break-word}
.ans-btn{font-size:11px;font-family:'Noto Sans KR',sans-serif;border-radius:20px;padding:4px 11px;cursor:pointer;border:1px solid var(--border);background:#fff;color:var(--muted);white-space:nowrap;transition:all .15s;flex-shrink:0}
.ans-tag{font-size:11px;background:var(--leaf-light);color:var(--leaf);padding:2px 9px;border-radius:20px;border:1px solid rgba(74,124,89,.2)}
.badge{font-size:11px;padding:2px 8px;border-radius:20px;white-space:nowrap}
.badge-cat{background:var(--sky-light);color:var(--sky)}
.badge-priv{background:var(--amber-light);color:var(--amber)}

.gi{background:#fff;border:1px solid var(--border);border-radius:var(--r);padding:16px 18px;margin-bottom:10px;animation:fu .25s ease both;transition:all .2s}
.gi.sel{border-color:var(--red);background:#FFF8F8}
.gi-date-group{font-family:'Noto Serif KR',serif;font-size:13px;color:var(--bark);font-weight:600;margin:18px 0 8px;padding-bottom:6px;border-bottom:1px solid var(--stone)}
.gi-entry{display:flex;align-items:flex-start;gap:8px;padding:8px 0;border-bottom:1px solid var(--warm)}
.gi-entry:last-child{border-bottom:none}
.gi-dot{width:6px;height:6px;border-radius:50%;background:var(--gold);flex-shrink:0;margin-top:6px}
.gi-body{flex:1}
.gi-who{font-size:11px;color:var(--muted);margin-bottom:2px}
.gi-content{font-size:14px;line-height:1.6;color:var(--text)}

.mi{background:#fff;border:1px solid var(--border);border-radius:var(--r);padding:18px 20px;margin-bottom:12px;animation:fu .25s ease both;transition:all .2s}
.mi.sel{border-color:var(--red);background:#FFF8F8}
.mi-ref{font-family:'Noto Serif KR',serif;font-size:13px;color:var(--sky);font-weight:600;margin-bottom:8px}
.mi-text{font-size:14px;line-height:1.7;color:var(--text);word-break:break-word}
.mi-footer{display:flex;align-items:center;justify-content:space-between;margin-top:12px}
.mi-who{display:flex;align-items:center;gap:6px}

.empty{text-align:center;padding:48px 0;color:var(--muted);font-size:14px;line-height:1.9}
.empty-icon{font-size:36px;display:block;margin-bottom:12px;opacity:.5}

.modal-bg{display:none;position:fixed;inset:0;background:rgba(44,36,25,.4);z-index:200;align-items:center;justify-content:center;padding:20px}
.modal-bg.open{display:flex}
.modal{background:#fff;border-radius:var(--r);padding:28px 22px 22px;width:100%;max-width:300px;box-shadow:0 20px 60px rgba(44,36,25,.2)}
.modal h3{font-family:'Noto Serif KR',serif;font-size:17px;color:var(--soil);margin-bottom:6px}
.modal p{font-size:13px;color:var(--muted);margin-bottom:16px;line-height:1.6}
.merr{font-size:13px;color:var(--red);margin-top:8px;display:none}
.mbtns{display:flex;gap:8px;margin-top:14px}
.mbtns button{flex:1;padding:11px;border-radius:var(--rs);font-size:14px;font-family:'Noto Sans KR',sans-serif;cursor:pointer;transition:all .15s}
.m-cancel{background:var(--warm);border:1px solid var(--border);color:var(--muted)}
.m-ok{background:var(--soil);border:none;color:#fff;font-weight:500}
.m-leaf{background:var(--leaf);border:none;color:#fff;font-weight:500}
.m-danger{background:var(--red);border:none;color:#fff;font-weight:500}

@keyframes fu{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
</style>
</head>
<body>

<div class="modal-bg" id="mLeader">
  <div class="modal">
    <h3>🔑 리더 확인</h3>
    <p>리더 비밀번호를 입력해주세요</p>
    <input type="password" id="pwInput" placeholder="비밀번호"/>
    <div class="merr" id="pwErr">비밀번호가 틀렸어요</div>
    <div class="mbtns">
      <button class="m-cancel" id="btnLeaderCancel">취소</button>
      <button class="m-ok" id="btnLeaderOk">확인</button>
    </div>
  </div>
</div>

<div class="modal-bg" id="mAns">
  <div class="modal">
    <h3>🙌 응답받으셨나요?</h3>
    <p id="mAnsMsg">이 기도제목을 응답됨으로 표시할까요?</p>
    <div class="mbtns">
      <button class="m-cancel" id="btnAnsNo">아직요</button>
      <button class="m-leaf" id="btnAnsYes">응답됐어요!</button>
    </div>
  </div>
</div>

<div class="modal-bg" id="mDelete">
  <div class="modal">
    <h3>🗑️ 삭제 확인</h3>
    <p id="delMsg">선택한 항목을 삭제할까요?<br>삭제하면 되돌릴 수 없어요.</p>
    <div class="mbtns">
      <button class="m-cancel" id="btnDelCancel">취소</button>
      <button class="m-danger" id="btnDelOk">삭제하기</button>
    </div>
  </div>
</div>

<div class="wrap">
  <div class="hd">
    <div class="hd-tag">🙏 곽유민조 기도방</div>
    <h1>함께 기도하고<br>감사해요</h1>
    <p id="todayDate"></p>
  </div>

  <div class="fam-wrap">
    <span class="fam-label">나는 누구예요?</span>
    <div class="fam-chips">
      <div class="fam-chip" data-name="곽유민">곽유민</div>
      <div class="fam-chip" data-name="김서현">김서현</div>
      <div class="fam-chip" data-name="박서현">박서현</div>
      <div class="fam-chip" data-name="이은휼">이은휼</div>
      <div class="fam-chip" data-name="김한을">김한을</div>
      <div class="fam-chip" data-name="최유진">최유진</div>
      <div class="fam-chip" data-name="조안나">조안나</div>
      <div class="fam-chip" data-name="이규환">이규환</div>
    </div>
  </div>

  <div class="tabs">
    <div class="tab on" id="tab0"><span class="tab-icon">🙏</span>기도제목</div>
    <div class="tab" id="tab1"><span class="tab-icon">🌱</span>감사일기</div>
    <div class="tab" id="tab2"><span class="tab-icon">📖</span>말씀묵상</div>
  </div>

  <div id="page0">
    <div id="prayForm">
      <div class="card">
        <span class="lbl">기도제목 <span class="req">*</span></span>
        <textarea class="md" id="prayText" placeholder="함께 기도해줄 내용을 써주세요 🙏"></textarea>
      </div>
      <div class="card">
        <span class="lbl">카테고리 (선택)</span>
        <div class="cats">
          <div class="cat">건강</div>
          <div class="cat">학업·직장</div>
          <div class="cat">가족</div>
          <div class="cat">신앙·영적성장</div>
          <div class="cat">관계</div>
          <div class="cat">기타</div>
        </div>
      </div>
      <div class="card">
        <span class="lbl">공개 범위</span>
        <div class="prv">
          <button class="prv-btn on" id="btnPub">✅ 모임에서 공개</button>
          <button class="prv-btn" id="btnPri">🔒 리더만 보기</button>
        </div>
      </div>
      <button class="btn-main" id="btnPraySubmit">기도제목 올리기</button>
    </div>
    <div class="ok" id="prayOk">
      <span class="ok-icon">🙏</span>
      <h2>함께 기도할게요</h2>
      <p>기도제목이 올라갔어요</p>
      <button class="out-btn" id="btnPrayReset">더 올리기</button>
    </div>
    <div style="margin-top:24px">
      <div class="lt">
        <span class="lc" id="prayCount">불러오는 중...</span>
        <div style="display:flex;gap:6px">
          <button class="ic-btn" id="btnPrayRefresh">↻ 새로고침</button>
          <button class="ic-btn" id="btnLeader">🔑 리더 보기</button>
        </div>
      </div>
      <div class="del-bar" id="delBarPray">
        <button class="sa-btn" id="btnSelAllPray">전체 선택</button>
        <span class="sc" id="selCountPray">0개 선택</span>
        <button class="d-btn" id="btnDelPray" disabled>삭제</button>
      </div>
      <div style="display:flex;gap:8px;margin-bottom:14px">
        <button class="ic-btn on" id="btnPrayTab0" style="background:var(--soil);color:#fff">기도 중</button>
        <button class="ic-btn" id="btnPrayTab1">응답됨 🙌</button>
      </div>
      <div id="prayList"><div class="empty"><span class="empty-icon">⏳</span>불러오는 중...</div></div>
    </div>
  </div>

  <div id="page1" style="display:none">
    <div id="thankForm">
      <div class="card">
        <span class="lbl">오늘 감사한 것 <span class="req">*</span></span>
        <textarea class="sm" id="thankText" placeholder="오늘 감사한 것 한 가지를 써주세요 🌱"></textarea>
      </div>
      <button class="btn-main btn-leaf" id="btnThankSubmit">감사 제목 올리기</button>
    </div>
    <div class="ok" id="thankOk">
      <span class="ok-icon">🌱</span>
      <h2>감사해요!</h2>
      <p>감사 제목이 올라갔어요</p>
      <button class="out-btn" id="btnThankReset">더 쓰기</button>
    </div>
    <div style="margin-top:24px">
      <div class="lt">
        <span class="lc" id="thankCount">불러오는 중...</span>
        <button class="ic-btn" id="btnThankRefresh">↻ 새로고침</button>
      </div>
      <div class="del-bar" id="delBarThank">
        <button class="sa-btn" id="btnSelAllThank">전체 선택</button>
        <span class="sc" id="selCountThank">0개 선택</span>
        <button class="d-btn" id="btnDelThank" disabled>삭제</button>
      </div>
      <div id="thankList"><div class="empty"><span class="empty-icon">⏳</span>불러오는 중...</div></div>
    </div>
  </div>

  <div id="page2" style="display:none">
    <div id="mediForm">
      <div class="card">
        <span class="lbl">본문 <span class="req">*</span></span>
        <input type="text" id="mediRef" placeholder="예: 시편 23:1-6"/>
      </div>
      <div class="card">
        <span class="lbl">묵상 기록 <span class="req">*</span></span>
        <textarea class="lg" id="mediText" placeholder="오늘 말씀을 통해 느낀 점, 적용할 점을 자유롭게 써주세요 📖"></textarea>
      </div>
      <button class="btn-main btn-sky" id="btnMediSubmit">묵상 나누기</button>
    </div>
    <div class="ok" id="mediOk">
      <span class="ok-icon">📖</span>
      <h2>말씀을 나눠줬어요</h2>
      <p>묵상이 올라갔어요</p>
      <button class="out-btn" id="btnMediReset">또 올리기</button>
    </div>
    <div style="margin-top:24px">
      <div class="lt">
        <span class="lc" id="mediCount">불러오는 중...</span>
        <button class="ic-btn" id="mediRefresh">↻ 새로고침</button>
      </div>
      <div class="del-bar" id="delBarMedi">
        <button class="sa-btn" id="btnSelAllMedi">전체 선택</button>
        <span class="sc" id="selCountMedi">0개 선택</span>
        <button class="d-btn" id="btnDelMedi" disabled>삭제</button>
      </div>
      <div id="mediList"><div class="empty"><span class="empty-icon">⏳</span>불러오는 중...</div></div>
    </div>
  </div>
</div>

<script>
var SHEET_URL='https://script.google.com/macros/s/AKfycbwgDl3adQitnAPJBTL_3NKPzOCk2hBB4DmWEvzjce7i1DyyajgItaROetafgy4cGXJY2Q/exec';
var SHEET_ID='1ijuLxnD6QItQtPPRmxK_WTM_bPhIIu74Jebm_BmOf7E';
var GVIZ='https://docs.google.com/spreadsheets/d/'+SHEET_ID+'/gviz/tq?tqx=out:json';
var LEADER_PW='0691';

var myName='',prayMode='active',isLeader=false;
var allPray=[],allThank=[],allMedi=[];
var checkedPray=[],checkedThank=[],checkedMedi=[];
var visiblePray=[],visibleThank=[],visibleMedi=[];
var curDelType='';

